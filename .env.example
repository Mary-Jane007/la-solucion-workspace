# ===========================================
# La-Solución – productie (kopieer naar .env op de server)
# ===========================================
# Verplicht in productie. Zonder deze waarden start de app niet (NODE_ENV=production).

NODE_ENV=production
PORT=4000

# Minimaal 32 tekens; genereer bijv. met: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=vervang_dit_door_een_lang_en_veilig_geheim_minstens_32_tekens

# Exacte URL(s) waar gebruikers de app openen (geen trailing slash). Gebruik HTTPS.
# Voor Vercel: zet hier je Vercel-URL, of meerdere gescheiden door komma (bijv. custom domain + Vercel).
CORS_ORIGIN=https://..........
APP_BASE_URL=https://..........

# PostgreSQL connection string (Neon, Supabase, Railway, etc.)
DATABASE_URL=........

# -------------------------------------------
# Optioneel: e-mail voor wachtwoord herstellen
# -------------------------------------------
# Als niet gezet: reset-link wordt alleen in de serverlogs getoond.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=..........

# E-mailadres van de eigenaar: ontvangt een e-mail bij elke nieuwe registratie (verificatie en toestemming)
OWNER_EMAIL=